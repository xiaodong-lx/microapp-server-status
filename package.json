{
  "name": "xiaodong-server-status",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "vite build",
    "build:dev": "cross-env NODE_ENV=development vite build",
    "pack": "npm run build && node build/pack.js",
    "pack:dev": "npm run build:dev && cross-env NODE_ENV=development node build/pack.js --dev",
    "gen": "node build/build.js",
    "gen:dev": "cross-env NODE_ENV=development node build/build.js --dev",
    "preview": "vite preview",
    "demo": "vite --config vite.config.js --open demo-usage.html",
    "clean": "rm -rf dist .build packages",
    "test": "node build/build.js && echo 'Build test passed'"
  },
  "devDependencies": {
    "@sun-panel/micro-app": "^1.0.15",
    "adm-zip": "^0.5.10",
    "cross-env": "^7.0.3",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "lit": "^3.3.2",
    "lit-html": "^3.3.2"
  }
}
